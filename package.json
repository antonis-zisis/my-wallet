{
  "name": "my-wallet",
  "version": "0.3.1",
  "type": "module",
  "private": true,
  "author": "Antonis Zisis",
  "description": "A personal budgeting app.",
  "license": "Elastic-2.0",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:web": "pnpm --filter my-wallet-web dev",
    "dev:server": "pnpm --filter my-wallet-server dev",
    "build": "pnpm run --parallel build",
    "test": "pnpm run --parallel test",
    "lint": "pnpm run --parallel lint",
    "typecheck": "pnpm run --parallel typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky",
    "env:encrypt": "./scripts/encrypt-envs.sh",
    "env:decrypt": "./scripts/decrypt-envs.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "packageManager": "pnpm@10.28.2"
}
